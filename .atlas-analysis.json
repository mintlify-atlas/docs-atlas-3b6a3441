  "keyFeatures": [
    "Student registration and profile management with photo and certificate uploads",
    "Bulk student import from Excel with comprehensive validation",
    "Role-based authentication system (administrators, teachers, students)",
    "Automated academic data synchronization from external systems",
    "Real-time student tracking with status management",
    "Email notifications for new student accounts",
    "Student search and filtering by career and semester",
    "Password management with temporary password support",
    "File storage and retrieval for student documents"
  ],
  "publicApiSurface": [
    "POST /auth/login - User authentication",
    "PUT /auth/change-password - Password update",
    "GET /alumnos/listado - List students with pagination and filters",
    "POST /alumnos/register - Register new student",
    "POST /alumnos/importar - Bulk import students from Excel",
    "GET /alumnos/detalle/{matricula} - Get student details",
    "PUT /alumnos/actualizar/{matricula} - Update student information",
    "POST /alumnos/set-base-id - Configure base student ID",
    "GET /alumnos/options - Get form options (careers, schools)",
    "GET /alumnos/archivos/{file_id} - Download student files",
    "GET /catalogos/estatus - Get student status catalog",
    "POST /sincronizacion/ejecutar - Trigger manual data synchronization"
  ]
}
